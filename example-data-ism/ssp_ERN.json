              "uuid": "9ff695f5-2d49-42e7-a01e-291bb7111d1a",
              "description": "The GPO sets the session logoff after 10 hours of user inactivity on all Windows desktop computers.",
              "implementation-status": {
                "state": "implemented"
              }
            }
          ]
        },
        {
          "uuid": "8c2b84b6-7c25-49d0-954d-a121a43042ec",
          "control-id": "ism-2012",
          "by-components": [
            {
              "component-uuid": "b541b5b3-e67a-495e-b8be-5ccb329ed128",
              "uuid": "2eeab264-938b-48e6-a68b-3731da7c6616",
              "description": "The GPO sets the windows screen lock to activate after 10 minutes of user inactivity on all Windows desktop computers.",
              "implementation-status": {
                "state": "implemented"
              }
            }
          ]
        },
        {
          "uuid": "bb159c98-99e7-4d61-a0d3-fbb410e0babc",
          "control-id": "ism-1175",
          "by-components": [
            {
              "component-uuid": "2bba09dd-2258-4079-87fe-1c4f051f3c49",
              "uuid": "31079304-d98e-4cec-890b-1590d5f18c6f",
              "description": "Priviledged user accounts cannot access the internet from this system.",
              "implementation-status": {
                "state": "implemented"
              }
            }
          ]
        },
        {
          "uuid": "0ca1876d-e26e-4f0e-afa1-fcba2d3ebf39",
          "control-id": "ism-0874",
          "by-components": [
            {
              "component-uuid": "2bba09dd-2258-4079-87fe-1c4f051f3c49",
              "uuid": "657e9d5f-e6a3-489b-915a-7ab2caf8037d",
              "description": "Mobile devices and desktop computers can not access the internet at all.",
              "implementation-status": {
                "state": "implemented"
              }
            }
          ]
        },
        {
          "uuid": "8df31dc3-2d45-4c7c-bb23-eaa493d5f3af",
          "control-id": "ism-1490",
          "by-components": [
            {
              "component-uuid": "2bba09dd-2258-4079-87fe-1c4f051f3c49",
              "uuid": "b4cddc25-3587-4c5f-8f51-d915ca72f7a1",
              "description": "There are no internet-facing servers on this system.",
              "implementation-status": {
                "state": "implemented"
              }
            }
          ]
        },
        {
          "uuid": "c08793e5-e2b0-4f23-ab77-d682e903585c",
          "control-id": "ism-1486",
          "by-components": [
            {
              "component-uuid": "2bba09dd-2258-4079-87fe-1c4f051f3c49",
              "uuid": "ea7f5769-a80b-4183-a908-ba138a7a2715",
              "description": "No web browser on this system can access the internet so can't process any java from the internet.",
              "implementation-status": {
                "state": "implemented"
              }
            }
          ]
        },
        {
          "uuid": "96dcbea3-0c8d-4775-b77e-fb1a7cb94cc9",
          "control-id": "ism-1485",
          "by-components": [
            {
              "component-uuid": "2bba09dd-2258-4079-87fe-1c4f051f3c49",
              "uuid": "e8625f9c-076c-4672-81c8-70ebbe8130c0",
              "description": "Web browser cannot process web advertisments from the internet as there is no access to the internet.",
              "implementation-status": {
                "state": "implemented"
              }
            }
          ]
        },
        {
          "uuid": "26e2735b-9693-46d4-ac08-940f61ba4faa",
          "control-id": "ism-1483",
          "by-components": [
            {
              "component-uuid": "2bba09dd-2258-4079-87fe-1c4f051f3c49",
              "uuid": "f853ae72-2861-4a55-a1e3-cefa40d1ffae",
              "description": "No servers can access the internet. However all servers should maintain the latest application release as per the software update policy.",
              "implementation-status": {
                "state": "implemented"
              }
            }
          ]
        },
        {
          "uuid": "ac1a82c7-490e-4642-b4eb-e9a7a5063504",
          "control-id": "ism-1978",
          "by-components": [
            {
              "component-uuid": "2bba09dd-2258-4079-87fe-1c4f051f3c49",
              "uuid": "9992fbd5-5420-43b3-b715-80cd7bcf14e9",
              "description": "No servers are internet-facing.",
              "implementation-status": {
                "state": "implemented"
              }
            }
          ]
        },
        {
          "uuid": "963671ff-7c9d-40d4-bf61-ae074320cf93",
          "control-id": "ism-1877",
          "by-components": [
            {
              "component-uuid": "2bba09dd-2258-4079-87fe-1c4f051f3c49",
              "uuid": "5482072e-0fe9-4256-a6b6-580fac95caf4",
              "description": "No servers, switches or desktops are internet-facing.\n\nThe network administrators will ensure all network encryptors  patches, updates or other vendor mitigation are applied as soon as practical.",
              "implementation-status": {
                "state": "implemented"
              }
            }
          ]
        },
        {
          "uuid": "6a66ebcb-b010-4ede-b517-233e99f837c4",
          "control-id": "ism-1753",
          "by-components": [
            {
              "component-uuid": "2bba09dd-2258-4079-87fe-1c4f051f3c49",
              "uuid": "5e59a0cd-b6e5-40e4-be6b-ed63ddbfa95b",
              "description": "All network encryptors will be replaced before they are no longer supported by vendors. As soon as end of life of encryptors is announced the plan and budget to replace this device will be allocated.",
              "implementation-status": {
                "state": "implemented"
              }
            }
          ]
        },
        {
          "uuid": "15048c01-4ddb-467b-926c-e0c8cdd16f64",
          "control-id": "ism-1906",
          "by-components": [
            {
              "component-uuid": "2bba09dd-2258-4079-87fe-1c4f051f3c49",
              "uuid": "f9894141-4510-428b-8a18-b3a83e20baf3",
              "description": "There are no internet-facing servers to collect event logs from.",
              "implementation-status": {
                "state": "implemented"
              }
            }
          ]
        },
        {
          "uuid": "a8446249-51a6-4ad7-85aa-f931e8970799",
          "control-id": "ism-1960",
          "by-components": [
            {
              "component-uuid": "2bba09dd-2258-4079-87fe-1c4f051f3c49",
              "uuid": "829bb527-da5a-4479-a583-a64c828537c5",
              "description": "All network encryptors will send events logs to central logging storage for central analysis and monitoring.\n\nNetwork administrators will check network encryptor event logs on the device weekly.",
              "implementation-status": {
                "state": "implemented"
              }
            }
          ]
        },
        {
          "uuid": "558b7ffb-1bbc-475f-92b0-407632f5b658",
          "control-id": "ism-1701",
          "by-components": [
            {
              "component-uuid": "2bba09dd-2258-4079-87fe-1c4f051f3c49",
              "uuid": "c4ac894b-1fb0-4c18-aad1-6463334e1af1",
              "description": "There are no internet-facing servers.\n\nA vulnerability scanner has a specific daily scheduled scan for the network encryptors.",
              "implementation-status": {
                "state": "implemented"
              }
            }
          ]
        },
        {
          "uuid": "54fcfd1d-4efe-4e9c-b786-57ed24bbf20b",
          "control-id": "ism-1818",
          "by-components": [
            {
              "component-uuid": "2bba09dd-2258-4079-87fe-1c4f051f3c49",
              "uuid": "6830c521-74f0-43fb-b8f8-32ccbf069d90",
              "description": "The system has no access to the internet. No authentication or authorisation of clients is allowed to happen outside of the system.",
              "implementation-status": {
                "state": "implemented"
              }
            }
          ]
        }
      ]
