              "uuid": "925c3ade-b3de-4bc2-a79f-d253b4733339",
              "description": "Airlock digital  implemented application control using publisher certificate rules. Publisher names and product names are used.",
              "implementation-status": {
                "state": "implemented"
              }
            }
          ]
        },
        {
          "uuid": "22cc2ab5-c0d5-4bea-970f-afac367e0d43",
